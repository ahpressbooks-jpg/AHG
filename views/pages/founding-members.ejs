<!-- Hero -->
<section class="section-hero section-hero--dark section-hero--full">
  <div class="container">
    <h1 class="section-hero__headline">We're Building This Right Now.<br>The Next Generation Can't Wait.</h1>
    <p class="section-hero__sub">AHG is pre-launch. The foundation is being laid. The people who show up first shape everything that comes after.</p>
  </div>
</section>

<!-- Success Banner (shown via JS when ?success=true is in URL) -->
<section class="section-success-banner" id="successBanner" style="display: none;">
  <div class="container">
    <div class="success-banner">
      <h2 class="success-banner__headline">You're In.</h2>
      <p class="success-banner__text">Welcome to the founding class. Your name goes in the first annual report. We'll reach you before anyone else hears a word.</p>
    </div>
  </div>
</section>

<!-- Two Conversion Paths -->
<section class="section-founding-paths">
  <div class="container">
    <div class="founding-paths">

      <!-- Path 1: Founding Member -->
      <div class="founding-path founding-path--primary">
        <span class="founding-path__label">FOUNDING MEMBER</span>
        <h2 class="founding-path__headline">Be a Founder.</h2>
        <div class="founding-path__price">
          <span class="founding-path__amount">$10</span>
          <span class="founding-path__interval">/month</span>
        </div>
        <p class="founding-path__text">Your name on the first page. You were here before it was finished.</p>
        <ul class="founding-path__perks">
          <li>Named in the inaugural annual report</li>
          <li>Early access to all program launches</li>
          <li>Direct updates from the founder</li>
          <li>Founding Member recognition</li>
        </ul>
        <form class="founding-payment-form" id="foundingPaymentForm">
          <div class="form-group">
            <label for="founding-name" class="form-label">Name</label>
            <input type="text" id="founding-name" name="name" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="founding-email" class="form-label">Email</label>
            <input type="email" id="founding-email" name="email" class="form-input" required>
          </div>
          <button type="submit" class="btn btn-primary btn-primary--lg btn--full">GET IN</button>
          <div class="form-feedback" id="foundingFeedback" aria-live="polite"></div>
        </form>
      </div>

      <!-- Path 2: Waitlist -->
      <div class="founding-path founding-path--secondary">
        <span class="founding-path__label">NOT READY YET?</span>
        <h2 class="founding-path__headline">Get on the List.</h2>
        <p class="founding-path__text">No payment. Just your name. When we launch, you hear first.</p>
        <form class="waitlist-form" id="waitlistForm">
          <div class="form-group">
            <label for="waitlist-name" class="form-label">Name</label>
            <input type="text" id="waitlist-name" name="name" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="waitlist-email" class="form-label">Email</label>
            <input type="email" id="waitlist-email" name="email" class="form-input" required>
          </div>
          <button type="submit" class="btn btn-outline btn--full">JOIN THE WAITLIST</button>
          <div class="form-feedback" id="waitlistFeedback" aria-live="polite"></div>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- Social Proof -->
<section class="section-social-proof">
  <div class="container">
    <div class="social-proof">
      <span class="social-proof__label">THE FOUNDING CLASS</span>
      <h2 class="social-proof__headline">First 100. First Page.</h2>
      <p class="social-proof__text">Every movement starts with the people who refused to wait. This is your name on the first page of something that will outlast all of us.</p>
      <a href="#foundingPaymentForm" class="btn btn-primary">CLAIM YOUR SPOT</a>
    </div>
  </div>
</section>

<script>
  // Show success banner if redirected from Stripe
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    document.getElementById('successBanner').style.display = '';
  }

  // Founding Member — Stripe Checkout
  document.getElementById('foundingPaymentForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const feedback = document.getElementById('foundingFeedback');
    const btn = form.querySelector('button[type="submit"]');

    btn.disabled = true;
    btn.textContent = 'PROCESSING...';
    feedback.className = 'form-feedback';
    feedback.textContent = '';

    try {
      const res = await fetch('/stripe/create-founding-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: form.name.value,
          email: form.email.value
        })
      });
      const data = await res.json();
      if (res.ok && data.url) {
        window.location.href = data.url;
      } else {
        feedback.className = 'form-feedback form-feedback--error';
        feedback.textContent = data.error || 'Something went wrong. Please try again.';
        btn.disabled = false;
        btn.textContent = 'GET IN';
      }
    } catch (err) {
      feedback.className = 'form-feedback form-feedback--error';
      feedback.textContent = 'Something went wrong. Please try again.';
      btn.disabled = false;
      btn.textContent = 'GET IN';
    }
  });

  // Waitlist Signup
  document.getElementById('waitlistForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const feedback = document.getElementById('waitlistFeedback');
    const btn = form.querySelector('button[type="submit"]');

    btn.disabled = true;
    btn.textContent = 'JOINING...';
    feedback.className = 'form-feedback';
    feedback.textContent = '';

    try {
      const res = await fetch('/api/founding-member/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: form.name.value,
          email: form.email.value
        })
      });
      const data = await res.json();
      if (res.ok) {
        feedback.className = 'form-feedback form-feedback--success';
        feedback.textContent = data.message;
        form.reset();
      } else {
        feedback.className = 'form-feedback form-feedback--error';
        feedback.textContent = data.error;
      }
    } catch (err) {
      feedback.className = 'form-feedback form-feedback--error';
      feedback.textContent = 'Something went wrong. Please try again.';
    }

    btn.disabled = false;
    btn.textContent = 'JOIN THE WAITLIST';
  });
</script>
