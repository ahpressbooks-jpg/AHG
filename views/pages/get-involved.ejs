<!-- Hero -->
<section class="section-hero section-hero--dark">
  <div class="container">
    <h1 class="section-hero__headline">Money Alone Won't Build This.</h1>
    <p class="section-hero__sub">We need people who show up.</p>
  </div>
</section>

<!-- Volunteer -->
<section class="section-volunteer" id="volunteer">
  <div class="container">
    <div class="section-volunteer__grid">
      <div class="section-volunteer__info">
        <span class="section-volunteer__label">VOLUNTEER</span>
        <h2 class="section-volunteer__headline">Show Up. Do Work.</h2>
        <p>AHG runs on people who give time, not just money. We need organizers, mentors, event support, and people willing to be in the room when it counts.</p>
        <p>Tell us what you bring. We'll tell you where you're needed.</p>
      </div>
      <div class="section-volunteer__form-wrap">
        <form class="volunteer-form form" id="volunteerForm">
          <div class="form__group">
            <label class="form__label" for="vol-name">Name <span class="form__required">*</span></label>
            <input class="form__input" type="text" id="vol-name" name="name" required autocomplete="name">
          </div>
          <div class="form__group">
            <label class="form__label" for="vol-email">Email <span class="form__required">*</span></label>
            <input class="form__input" type="email" id="vol-email" name="email" required autocomplete="email">
          </div>
          <div class="form__group">
            <label class="form__label" for="vol-phone">Phone</label>
            <input class="form__input" type="tel" id="vol-phone" name="phone" autocomplete="tel">
          </div>
          <div class="form__group">
            <label class="form__label" for="vol-skills">Skills &amp; Experience</label>
            <textarea class="form__textarea" id="vol-skills" name="skills" rows="3" placeholder="What do you bring?"></textarea>
          </div>
          <div class="form__group">
            <label class="form__label" for="vol-availability">Availability</label>
            <select class="form__select" id="vol-availability" name="availability">
              <option value="">Select availability</option>
              <option value="weekdays">Weekdays</option>
              <option value="weekends">Weekends</option>
              <option value="both">Both</option>
              <option value="flexible">Flexible</option>
            </select>
          </div>
          <div class="form__group">
            <label class="form__label" for="vol-message">Message</label>
            <textarea class="form__textarea" id="vol-message" name="message" rows="3" placeholder="Anything else we should know."></textarea>
          </div>
          <button class="btn btn-primary form__submit" type="submit">SUBMIT</button>
          <p class="form__status" id="volunteerStatus" hidden></p>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Corporate Partnership -->
<section class="section-partner" id="partner">
  <div class="container">
    <div class="section-partner__inner">
      <span class="section-partner__label">CORPORATE PARTNERSHIP</span>
      <h2 class="section-partner__headline">Put Your Organization Behind This.</h2>
      <p>Not a logo swap. A commitment backed by resources and accountability. Three tiers starting at $5,000/year. Each includes co-branded recognition, access to programs and events, and a dedicated coordinator.</p>
      <p>If your organization wants to be associated with the fight for the next generation, this is how.</p>
      <a href="/contact?subject=Corporate%20Partnership" class="btn btn-primary">CONTACT US</a>
    </div>
  </div>
</section>

<!-- Speak at AHG -->
<section class="section-speaker" id="speak">
  <div class="container">
    <div class="section-speaker__grid">
      <div class="section-speaker__info">
        <span class="section-speaker__label">SPEAK AT AHG</span>
        <h2 class="section-speaker__headline">Got Something to Say? Say It Here.</h2>
        <p>We host summits, town halls, and community events where real talk shapes real outcomes. Expertise, lived experience, or a message the next generation needs to hear.</p>
        <p>We prioritize speakers under 30. But the mic is open to anyone with something worth hearing.</p>
      </div>
      <div class="section-speaker__form-wrap">
        <form class="speaker-form form" id="speakerForm">
          <div class="form__group">
            <label class="form__label" for="spk-name">Name <span class="form__required">*</span></label>
            <input class="form__input" type="text" id="spk-name" name="name" required autocomplete="name">
          </div>
          <div class="form__group">
            <label class="form__label" for="spk-email">Email <span class="form__required">*</span></label>
            <input class="form__input" type="email" id="spk-email" name="email" required autocomplete="email">
          </div>
          <div class="form__group">
            <label class="form__label" for="spk-org">Organization</label>
            <input class="form__input" type="text" id="spk-org" name="organization" autocomplete="organization">
          </div>
          <div class="form__group">
            <label class="form__label" for="spk-topic">Topic <span class="form__required">*</span></label>
            <input class="form__input" type="text" id="spk-topic" name="topic" required placeholder="What would you speak about?">
          </div>
          <div class="form__group">
            <label class="form__label" for="spk-bio">Bio</label>
            <textarea class="form__textarea" id="spk-bio" name="bio" rows="4" placeholder="Who are you and why should we listen?"></textarea>
          </div>
          <button class="btn btn-primary form__submit" type="submit">SUBMIT</button>
          <p class="form__status" id="speakerStatus" hidden></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    function handleFormSubmit(formEl, endpoint, statusEl) {
      formEl.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = formEl.querySelector('.form__submit');
        btn.disabled = true;
        btn.textContent = 'Submitting...';
        statusEl.hidden = true;

        var data = {};
        new FormData(formEl).forEach(function(value, key) {
          data[key] = value;
        });

        fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
        .then(function(res) { return res.json(); })
        .then(function(result) {
          statusEl.hidden = false;
          if (result.success) {
            statusEl.className = 'form__status form__status--success';
            statusEl.textContent = result.message;
            formEl.reset();
          } else {
            statusEl.className = 'form__status form__status--error';
            statusEl.textContent = result.error || 'Something went wrong. Please try again.';
          }
          btn.disabled = false;
          btn.textContent = 'SUBMIT';
        })
        .catch(function() {
          statusEl.hidden = false;
          statusEl.className = 'form__status form__status--error';
          statusEl.textContent = 'Connection error. Please try again.';
          btn.disabled = false;
          btn.textContent = 'SUBMIT';
        });
      });
    }

    handleFormSubmit(
      document.getElementById('volunteerForm'),
      '/api/volunteer',
      document.getElementById('volunteerStatus')
    );

    handleFormSubmit(
      document.getElementById('speakerForm'),
      '/api/speaker',
      document.getElementById('speakerStatus')
    );
  })();
</script>
