<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('_sidebar', { active: 'volunteers', adminName }) %>
    <div class="admin-main">
      <div class="admin-header">
        <h1>Volunteer Applications</h1>
        <div class="admin-user"><strong><%= volunteers.length %></strong> total</div>
      </div>

      <div class="admin-card">
        <div class="admin-card-body">
          <% if (volunteers.length === 0) { %>
            <div class="empty-state">
              <h3>No Volunteer Applications Yet</h3>
              <p>Applications from the Get Involved page will appear here.</p>
            </div>
          <% } else { %>
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Skills</th>
                  <th>Availability</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% volunteers.forEach(v => { %>
                  <tr id="vol-<%= v.id %>">
                    <td><strong><%= v.name %></strong></td>
                    <td class="mono"><%= v.email %></td>
                    <td><%= v.phone || '—' %></td>
                    <td style="max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= v.skills || '—' %></td>
                    <td><%= v.availability || '—' %></td>
                    <td><span class="badge badge-<%= v.status %>"><%= v.status.toUpperCase() %></span></td>
                    <td class="mono"><%= new Date(v.created_at).toLocaleDateString() %></td>
                    <td>
                      <button class="btn-action btn-action-danger" onclick="deleteVol(<%= v.id %>)">Remove</button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <script>
    async function deleteVol(id) {
      if (!confirm('Remove this application?')) return;
      const res = await fetch('/admin/volunteers/' + id, { method: 'DELETE' });
      if (res.ok) document.getElementById('vol-' + id).remove();
    }
  </script>
</body>
</html>
