<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('_sidebar', { active: 'founding-members', adminName }) %>
    <div class="admin-main">
      <div class="admin-header">
        <h1>Founding Members</h1>
        <div class="admin-user"><strong><%= members.length %></strong> total</div>
      </div>

      <div class="stat-cards" style="margin-bottom: 24px;">
        <div class="stat-card">
          <div class="stat-card-label">Paid Members</div>
          <div class="stat-card-number"><%= members.filter(m => m.type === 'paid').length %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Waitlist</div>
          <div class="stat-card-number"><%= members.filter(m => m.type === 'waitlist').length %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Goal: 100</div>
          <div class="stat-card-number"><%= Math.round((members.length / 100) * 100) %>%</div>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-body">
          <% if (members.length === 0) { %>
            <div class="empty-state">
              <h3>No Founding Members Yet</h3>
              <p>Share the founding member campaign to get started.</p>
            </div>
          <% } else { %>
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Type</th>
                  <th>Joined</th>
                </tr>
              </thead>
              <tbody>
                <% members.forEach(m => { %>
                  <tr>
                    <td><strong><%= m.name %></strong></td>
                    <td class="mono"><%= m.email %></td>
                    <td><span class="badge badge-<%= m.type %>"><%= m.type.toUpperCase() %></span></td>
                    <td class="mono"><%= new Date(m.created_at).toLocaleDateString() %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
