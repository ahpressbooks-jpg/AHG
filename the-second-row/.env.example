# THE SECOND ROW — environment
# Every variable is OPTIONAL. The site runs with none of them (RSS-only,
# in-memory board). Each key you add switches on a layer.

# --- Memory (recommended first) -------------------------------------------
# Upstash Redis (or Vercel KV / Upstash-for-Redis marketplace integration).
# Persists the board, story biographies, sweep log, desk overrides, and the
# email list across deploys and cold starts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# (Vercel KV naming also works: KV_REST_API_URL / KV_REST_API_TOKEN)

# --- The Control Room -------------------------------------------------------
# Set a strong password to open /desk (pin, force-tier, kill, confirm FLASH).
DESK_PASSWORD=

# --- Enrichment (each one optional, budgeted, non-fatal) -------------------
# Tier 1 · Firecrawl: clean excerpts for top-of-house stories.
FIRECRAWL_API_KEY=
# Tier 2 · Parallel: web corroboration counts for stories in motion.
PARALLEL_API_KEY=
# Tier 3 · LLM triage: normalized headlines + civic-gravity scoring.
ANTHROPIC_API_KEY=
TRIAGE_MODEL=claude-haiku-4-5-20251001

# --- Operations --------------------------------------------------------------
# Protects /api/sweep; Vercel Cron sends it automatically as a Bearer token.
CRON_SECRET=
# Canonical URL for metadata/sitemaps, e.g. https://thesecondrow.com
NEXT_PUBLIC_SITE_URL=

# --- v2 · The Permanent Record & the till -----------------------------------
AUTH_SECRET=
RESEND_API_KEY=
AUTH_EMAIL_FROM="The Second Row <seat@yourdomain.com>"
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_FOUNDING=
DESK_TZ=
